# =============================================================================
# Parallel Processing Configuration (optional - auto-detected if not set)
# =============================================================================
# These settings control the parallel processing behavior for AI pipeline.
# If not set, optimal values are auto-detected based on hardware (CPU, RAM, GPU).
# Uncomment and modify to override auto-detected values.

# Number of worker threads/processes (default: 2x CPU cores if GPU, else 1x CPU cores, max 32)
# PARALLEL_MAX_WORKERS=16

# General batch size for document processing (default: 256 for 16GB+ GPU, 128 for 8GB+, 32 otherwise)
# PARALLEL_BATCH_SIZE=256

# Batch size for GPU inference (classifier, toxic, emotion models)
# PARALLEL_GPU_BATCH_SIZE=128

# Batch size for embedding generation (higher due to simpler computation)
# PARALLEL_EMBEDDING_BATCH_SIZE=512

# Max concurrent LLM/Ollama requests (default: RAM_GB / 2, max 32)
# PARALLEL_MAX_CONCURRENT_LLM=32

# Chunk size for streaming file reading (default: 50000 records per chunk)
# PARALLEL_CHUNK_SIZE=50000

# Use multiprocessing instead of threading (default: true on Linux, false on macOS/Windows)
# PARALLEL_USE_MULTIPROCESSING=true

# Enable performance monitoring (default: true)
# PARALLEL_ENABLE_MONITORING=true

# Enable auto-optimization based on system load (default: true)
# PARALLEL_ENABLE_AUTO_OPTIMIZATION=true

# Max retries for failed tasks (default: 3)
# PARALLEL_MAX_RETRIES=3

# Timeout for processing tasks in seconds (default: 300)
# PARALLEL_TIMEOUT_SECONDS=300