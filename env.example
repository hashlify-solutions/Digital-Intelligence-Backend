# Digital Intelligence Platform Environment Variables
# Copy this file to .env and update the values according to your environment

# Application Settings
APP_NAME="Digital Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT="development"  # development, staging, production

# Server Settings
HOST="0.0.0.0"
PORT=8000

# Database Settings - MongoDB
# Option 1: Use full connection string (recommended for production)
MONGO_URI="mongodb+srv://hashlifysolutions:Shinigami@hashlify01@cluster0.q5atq.mongodb.net/DigitalIntelligence"

# Option 2: Use individual components (for flexibility)
MONGO_USERNAME="your_username"
MONGO_PASSWORD="your_password"
MONGO_HOST="cluster0.q5atq.mongodb.net"
MONGO_DATABASE="DigitalIntelligence"

# Vector Database Settings - Qdrant
QDRANT_URL="https://your-qdrant-instance.com:6333"
QDRANT_API_KEY="your_qdrant_api_key"

# Celery & Redis Settings
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
REDIS_URL="redis://localhost:6379/0"

# AI/ML Model Settings
LOCAL_MODELS=True  # Set to False for production/cloud deployment
DI_DEVICE="cpu"  # cpu, cuda (for GPU acceleration)

# Security Settings
SECRET_KEY="your-super-secret-key-change-in-production"
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage Settings
UPLOAD_DIR="data"
LOGO_DIR="logo"
MAX_FILE_SIZE=104857600  # 100MB in bytes

# External API Settings (optional)
OPENAI_API_KEY="your_openai_api_key"
HUGGINGFACE_TOKEN="your_huggingface_token"

# Logging Settings
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE="app.log"

# CORS Settings
CORS_ORIGINS="*"  # Use comma-separated list for multiple origins: "http://localhost:3000,https://yourdomain.com"
